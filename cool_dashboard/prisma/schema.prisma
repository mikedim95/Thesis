// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id      Int      @id @default(autoincrement())
  email   String   @unique
  userName    String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// EdgeGroup table
model EdgeGroup {
  GroupID            String       @id
  InfrastructureType String
  AssociatedDevices  Int
  // Connection with AnomalyEvent
  anomalies         AnomalyEvent[]
  createdAt         DateTime @default(now())
  HasDevices        EdgeDevice[]
}

// EdgeDevice table
model EdgeDevice {
  EdgeID         String       @id
  GroupID        String
  InGroup        EdgeGroup    @relation(fields:[GroupID],references:[GroupID])
  Status         String
  SensorsNumber Int
  // Connection with AnomalyEvent
  anomalies      AnomalyEvent[]
  createdAt         DateTime @default(now())
}

// AnomalyEvent table
model AnomalyEvent {
  ID                  Int      @id @default(autoincrement())
  EdgeID              String
  GroupID             String
  MLMethodUsed        String
  DatapointsBeforeAnomaly Int[]
  AnomalyDatapoints   Int[]
  DatapointsAfterAnomaly Int[]
  AnomalyDatapointsNo Int
  // Connections with EdgeGroup and EdgeDevice
  edgeGroup   EdgeGroup   @relation(fields: [GroupID], references: [GroupID])
  edgeDevice  EdgeDevice  @relation(fields: [EdgeID], references: [EdgeID])
  createdAt         DateTime @default(now())
}