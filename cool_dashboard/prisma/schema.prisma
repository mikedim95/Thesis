// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  userName  String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// EdgeGroup table
model EdgeGroup {
  groupName          String       @id
  infrastructureType String
  createdAt          DateTime     @default(now())
  has                EdgeDevice[]
}

// EdgeDevice table
model EdgeDevice {
  edgeName      String
  groupName     String
  status        String
  createdAt     DateTime       @default(now())
  GroupRelation EdgeGroup      @relation(fields: [groupName], references: [groupName])
  reports       AnomalyEvent[]

  @@id([edgeName, groupName])
}

// AnomalyEvent table
model AnomalyEvent {
  anomalyId              Int        @id @default(autoincrement())
  edgeDeviceEdgeName     String
  edgeDeviceGroupName    String
  mLMethodUsed           String
  datapointsBeforeAnomaly Int[]
  anomalyDatapoints      Int[]
  datapointsAfterAnomaly Int[]
  createdAt              DateTime   @default(now())

  // Define relation to EdgeDevice
  edgeDevice             EdgeDevice @relation(fields: [edgeDeviceEdgeName, edgeDeviceGroupName], references: [edgeName, groupName])
}

