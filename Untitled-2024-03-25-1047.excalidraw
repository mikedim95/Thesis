      "updated": 1717256842426,
      "link": null,
      "locked": false,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "Why Containers?",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why Containers?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 751,
      "versionNonce": 1654567189,
      "index": "b0R",
      "isDeleted": false,
      "id": "GUwcG4piYXpSZOi-AhAdW",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2495.1271092605357,
      "y": -521.6481363406513,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 739.2994995117188,
      "height": 250,
      "seed": 839424155,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1717256842426,
      "link": null,
      "locked": false,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "Pros:\n    ! Easy packeging method for later multiple distribution\n    ! Provide scalability to remote edge computers\n    ! Provide security while appropriate methods apply\n    ! There can be data persistense after a reboot\n    ! There are many tools that come with (Automatic firmware updates, \n    orchestrasion in case of local microservices)\n    ! Gives the team of devs a monolithic approach on deployment with \n    docker-compose, instead of coping with separate different commands \n    in each dev laptop",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pros:\n    ! Easy packeging method for later multiple distribution\n    ! Provide scalability to remote edge computers\n    ! Provide security while appropriate methods apply\n    ! There can be data persistense after a reboot\n    ! There are many tools that come with (Automatic firmware updates, \n    orchestrasion in case of local microservices)\n    ! Gives the team of devs a monolithic approach on deployment with \n    docker-compose, instead of coping with separate different commands \n    in each dev laptop",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 440,
      "versionNonce": 548427451,
      "index": "b0S",
      "isDeleted": false,
      "id": "Oan4qSvH7Rve_TP4J2HVH",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 2505.166112718315,
      "y": -203.93763021193445,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 665.3795166015625,
      "height": 100,
      "seed": 1375310459,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1717256842426,
      "link": null,
      "locked": false,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "Cons:\n    ! They add overhead (slower than bare metal firmware version)\n    ! Chalenging learning curve\n    ! Download and build time (can be dealt with)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cons:\n    ! They add overhead (slower than bare metal firmware version)\n    ! Chalenging learning curve\n    ! Download and build time (can be dealt with)",
      "autoResize": true,
      "lineHeight": 1.25
    },
